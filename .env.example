# ── Required API keys ────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_key_here
GROQ_API_KEY=your_groq_key_here

# ── Pipecat WebSocket transport ───────────────────────────────────────────────
# For local dev, Pipecat's built-in WebSocket transport is used (no Daily needed)
# For production, swap to Daily transport — add DAILY_API_KEY here
TRANSPORT=websocket
# TRANSPORT=daily
# DAILY_API_KEY=your_daily_key_here

# ── LLM settings ─────────────────────────────────────────────────────────────
GROQ_MODEL=qwen-qwq-32b
# fallback if Qwen quota exceeded:
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# ── TTS settings ─────────────────────────────────────────────────────────────
# Kokoro voice: af_heart = warm female English (best for eldercare)
# Options: af_heart, af_sky, am_echo, am_michael, bf_emma, bm_george
KOKORO_VOICE=af_heart
KOKORO_SPEED=0.92          # slightly slower for elderly users

# ── App ───────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8765                  # WebSocket port
LOG_LEVEL=INFO
